# =========================================
# E-Commerce API - Environment Variables (EXAMPLE)
# =========================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env

# --- MySQL ---
MYSQL_ROOT_PASSWORD=YourStrong!Passw0rd
MYSQL_DATABASE=Fashion_Site
MYSQL_USER=appuser
MYSQL_PASSWORD=YourStrong!Passw0rd

# --- Connection Strings ---
ConnectionStrings__DBbyMonster=Server=mysql;Port=3306;Database=Fashion_Site;User Id=appuser;Password=YourStrong!Passw0rd;SslMode=None;Allow User Variables=True;AllowPublicKeyRetrieval=True;
ConnectionStrings__Redis=redis:6379

# --- Frontend URL ---
FrontEndUrl=https://your-frontend-url.example.com

# --- Cloudinary ---
CloudinarySettings__CloudName=your_cloud_name
CloudinarySettings__ApiKey=your_api_key
CloudinarySettings__ApiSecret=your_api_secret

# --- JWT ---
Jwt__Key=your_jwt_secret_key_at_least_64_characters_long_change_me_now
Jwt__Issuer=your_issuer
Jwt__Audience=your_audience
Jwt__ExpiresInMinutes=10

# --- Email (SMTP) ---
Email__Address=your_email@gmail.com
Email__Password=your_app_password
Email__Host=smtp.gmail.com
Email__Port=587
Email__services=your_service_email@gmail.com

# --- HangFire Dashboard Auth ---
HangFireAuth__UserName=admin
HangFireAuth__Pass=ChangeThisPassword!

# --- Google OAuth ---
Security__ExternalServices__Google__ClientId=your_google_client_id.apps.googleusercontent.com
Security__ExternalServices__Google__ClientSecret=your_google_client_secret

# --- Paymob ---
Security__Paymob__HMAC=your_paymob_hmac_secret
Security__Paymob__redirection_url=https://your-frontend-url.example.com/orders
